rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "admin";
    }

    function isValidNews(data) {
      return data.title is string
        && data.title.size() > 0
        && data.category is string
        && data.author is string
        && data.excerpt is string
        && data.body is string
        && data.image is string
        && data.published is bool
        && (!('views' in data) || (data.views is int && data.views >= 0));
    }

    function isNewsViewIncrement() {
      return resource.data.published == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        && request.resource.data.views is int
        && request.resource.data.views == resource.data.get('views', 0) + 1;
    }

    function isValidWelcomeVideo(data) {
      return data.title is string
        && data.title.size() > 0
        && data.description is string
        && data.youtubeId is string
        && data.published is bool;
    }

    function isValidVolunteer(data) {
      return data.fullName is string
        && data.fullName.size() > 0
        && data.fullName.size() <= 120
        && data.email is string
        && data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && data.phone is string
        && data.phone.size() > 0
        && data.phone.size() <= 40
        && data.province is string
        && data.province.size() > 0
        && data.interest is string
        && data.interest.size() > 0
        && data.message is string
        && data.message.size() <= 2000;
    }

    function isValidEvent(data) {
      return data.title is string
        && data.title.size() > 0
        && data.description is string
        && data.location is string
        && data.location.size() > 0
        && data.published is bool;
    }

    function isValidDeclaration(data) {
      return data.headline is string
        && data.headline.size() > 0
        && data.message is string
        && data.message.size() > 0
        && data.body is string;
    }

    match /subscribers/{email} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.email == email
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.keys().hasAll(['email', 'source', 'subscribedAt'])
        && request.resource.data.source is string;
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /news/{articleId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create: if isAdmin() && isValidNews(request.resource.data);
      allow update: if (isAdmin() && isValidNews(request.resource.data))
        || isNewsViewIncrement();
      allow delete: if isAdmin();
    }

    match /content/declaration {
      allow read: if true;
      allow create, update: if isAdmin() && isValidDeclaration(request.resource.data);
    }

    match /content/welcome-video {
      allow read: if true;
      allow create, update: if isAdmin() && isValidWelcomeVideo(request.resource.data);
    }

    match /volunteers/{volunteerId} {
      allow read: if isAdmin();
      allow create: if isValidVolunteer(request.resource.data)
        && request.resource.data.keys().hasAll([
          'fullName',
          'email',
          'phone',
          'province',
          'interest',
          'message',
          'registeredAt'
        ]);
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create: if isAdmin() && isValidEvent(request.resource.data);
      allow update: if isAdmin() && isValidEvent(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
